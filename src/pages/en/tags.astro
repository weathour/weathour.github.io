---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getTagList } from "@utils/content-utils";
import { getTagUrl } from "@utils/url-utils";

const locale = "en" as const;
const tags = await getTagList(locale);
---

<MainGridLayout locale={locale} title="Tags" lang={locale}>
	<div class="card-base px-6 py-6 md:px-9 md:py-8">
		<h1 class="text-3xl font-bold mb-3">Tags</h1>
		<p class="text-neutral-500 dark:text-neutral-400 mb-6">
			Browse posts by tag. Clicking a tag opens the archive page with filtering applied.
		</p>

		<div class="flex flex-wrap gap-3">
			{tags.map((tag) => (
				<a
					href={getTagUrl(tag.name, locale)}
					class="btn-regular rounded-xl px-4 py-2 text-sm font-medium active:scale-95"
				>
					{tag.name} <span class="opacity-70">({tag.count})</span>
				</a>
			))}
		</div>
	</div>
</MainGridLayout>
